alias ..='cd ..'
alias cp='cp -i'
alias mv='mv -i'
if rm --version 2>/dev/null | grep -q GNU; then
    alias rm='rm -I'
else
    alias rm='rm -i'
fi
command -v nvim >/dev/null 2>&1 && alias vim=nvim
command -v lazygit >/dev/null 2>&1 && alias lg=lazygit
if command -v eza >/dev/null 2>&1; then
    alias ls='eza'
    alias ll='eza -lah --git'
    alias lt='eza --tree --level=2'
    alias la='eza -a'
else
    alias ll='ls -lah'
    alias la='ls -a'
fi
command -v kitty >/dev/null 2>&1 && alias ssh="kitty +kitten ssh"

if command -v fzf >/dev/null 2>&1; then
    export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border --info=inline'
    if command -v fd >/dev/null 2>&1; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude=.git --exclude=node_modules --no-ignore-vcs'
        export FZF_CTRL_T_COMMAND=$FZF_DEFAULT_COMMAND
    fi
fi

# Scaffold a direnv .envrc for a Python venv at .venv.
# The leading `-` is a convention for personal helpers (tab `-<TAB>` lists them).
-make-python-envrc() {
    if [[ -f .envrc ]]; then
        echo "Cowardly refusing to overwrite existing .envrc file"
    else
        {
            echo "# vim: ft=sh"
            echo "export VIRTUAL_ENV=.venv"
            echo "layout python-venv"
        } >.envrc
    fi
}

# Track personal files inside a shared project without them ever touching the
# shared repo's history: a second bare repo over the same working tree, keyed
# off the project's own toplevel path so it works from any of several projects.
_pgit_dir() {
    local worktree slug
    worktree=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "pgit: not inside a git project" >&2; return 1; }
    slug=$(echo "$worktree" | sed 's|/|-|g; s|^-||')
    echo "$HOME/.local/share/git-personal/${slug}.git"
}

pgit() {
    local worktree gitdir
    worktree=$(git rev-parse --show-toplevel) || return 1
    gitdir=$(_pgit_dir) || return 1
    git --git-dir="$gitdir" --work-tree="$worktree" "$@"
}

# Reuse git's own completion (subcommands, branches, etc.) for pgit.
if [[ -n "$ZSH_VERSION" ]] && command -v compdef >/dev/null 2>&1; then
    compdef pgit=git
elif [[ -n "$BASH_VERSION" ]] && declare -F __git_complete >/dev/null 2>&1; then
    __git_complete pgit __git_main
fi

# One-time per project: pgit-init <file...>
# Creates the bare repo, silences untracked-file noise, and excludes the
# given files from the shared repo's own git status (via .git/info/exclude).
pgit-init() {
    local worktree gitdir
    worktree=$(git rev-parse --show-toplevel) || return 1
    gitdir=$(_pgit_dir) || return 1
    git init --bare "$gitdir"
    git --git-dir="$gitdir" --work-tree="$worktree" config --local status.showUntrackedFiles no
    for f in "$@"; do
        echo "$f" >> "$worktree/.git/info/exclude"
    done
    echo "Personal repo ready: $worktree -> $gitdir"
}
