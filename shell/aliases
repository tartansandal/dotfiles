alias ..='cd ..'
alias cp='cp -i'
alias mv='mv -i'
if rm --version 2>/dev/null | grep -q GNU; then
    alias rm='rm -I'
else
    alias rm='rm -i'
fi
command -v nvim >/dev/null 2>&1 && alias vim=nvim
command -v lazygit >/dev/null 2>&1 && alias lg=lazygit
if command -v eza >/dev/null 2>&1; then
    alias ls='eza'
    alias ll='eza -lah --git'
    alias lt='eza --tree --level=2'
    alias la='eza -a'
else
    alias ll='ls -lah'
    alias la='ls -a'
fi
command -v kitty >/dev/null 2>&1 && alias ssh="kitty +kitten ssh"

if command -v fzf >/dev/null 2>&1; then
    export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border --info=inline'
    if command -v fd >/dev/null 2>&1; then
        export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude=.git --exclude=node_modules --no-ignore-vcs'
        export FZF_CTRL_T_COMMAND=$FZF_DEFAULT_COMMAND
    fi
fi

# Scaffold a direnv .envrc for a Python venv at .venv.
# The leading `-` is a convention for personal helpers (tab `-<TAB>` lists them).
-make-python-envrc() {
    if [[ -f .envrc ]]; then
        echo "Cowardly refusing to overwrite existing .envrc file"
    else
        {
            echo "# vim: ft=sh"
            echo "export VIRTUAL_ENV=.venv"
            echo "layout python-venv"
        } >.envrc
    fi
}
