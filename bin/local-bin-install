#!/usr/bin/env bash
# local-bin-install — fetch prebuilt CLI tools into ~/.local/bin (no root needed)
#
# Usage:
#   local-bin-install                 # install/update every known tool
#   local-bin-install nvim rg fd      # only the named ones
#   local-bin-install --list          # list available tools
#
# For unprivileged accounts on Linux (x86_64 / aarch64) where the system
# package manager is off-limits. Pulls static release binaries from upstream
# GitHub releases into ~/.local/bin (already on PATH via ~/.zprofile);
# Neovim's runtime and Node's tree are unpacked into ~/.local/. Zsh completions
# are generated into ~/.local/share/zsh/site-functions (put on fpath by
# ~/.zshrc). Safe to re-run to update.
#
# Not covered here on purpose: anything needing a compiler.
#
# Trust model: artifacts come from official upstream release URLs over HTTPS with
# cert validation, redirects pinned to HTTPS (see CURL below). That TLS link is the
# integrity boundary — there's deliberately no checksum/signature check: a checksum
# fetched from the same release over the same TLS adds nothing an attacker couldn't
# also forge, and most of these projects publish no signatures. Accepted risk: a
# compromised upstream release (this always pulls "latest"). Want more? Pin
# version+hash in-repo, or verify signatures (node provides them).

# shellcheck disable=SC2329  # installer functions are dispatched via the TOOLS map
set -euo pipefail

PREFIX="${LOCAL_BIN_PREFIX:-$HOME/.local}"
BIN="$PREFIX/bin"
COMP="$PREFIX/share/zsh/site-functions"   # zsh completions; put on fpath by ~/.zshrc

ORDER=(nvim node rg fd eza fzf lazygit delta tree-sitter starship uv copilot direnv)
case "${1:-}" in
  -h|--help) printf 'usage: local-bin-install [--list] [tool ...]\nbinaries -> %s\ncompletions -> %s\ntools: %s\n' "$BIN" "$COMP" "${ORDER[*]}"; exit 0 ;;
  --list)    printf '%s\n' "${ORDER[@]}"; exit 0 ;;
esac

[ "$(uname -s)" = Linux ] || { echo "local-bin-install: Linux only (this is $(uname -s))" >&2; exit 1; }

case "$(uname -m)" in
  x86_64|amd64)  ARCH=x86_64;  GOARCH=amd64 ;;
  aarch64|arm64) ARCH=aarch64; GOARCH=arm64 ;;
  *) echo "local-bin-install: unsupported arch $(uname -m)" >&2; exit 1 ;;
esac

have() { command -v "$1" >/dev/null 2>&1; }
have curl || { echo "local-bin-install: needs 'curl'" >&2; exit 1; }
have tar  || { echo "local-bin-install: needs 'tar'"  >&2; exit 1; }
have gzip || { echo "local-bin-install: needs 'gzip'" >&2; exit 1; }

# Every download goes through this: HTTPS only, and refuse a plaintext hop even
# if a redirect tries one (-L would otherwise happily follow an http:// target).
CURL=(curl --proto '=https' --proto-redir '=https')

mkdir -p "$BIN" "$COMP"   # binaries + zsh completions; only after preconditions pass

msg()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33mwarning:\033[0m %s\n' "$*" >&2; }

# Latest release tag for a GitHub repo via the /releases/latest redirect
# (no API token, no rate limit). Prints e.g. "v0.26.8" or "14.1.1".
gh_latest() {
  local repo=$1 url
  url=$("${CURL[@]}" -fsSLI -o /dev/null -w '%{url_effective}' "https://github.com/$repo/releases/latest") \
    || { warn "could not resolve latest release for $repo"; return 1; }
  basename "$url"
}

# Download a .tar.gz from $1, extract into a fresh temp dir, print the dir.
untar_url() {
  local tmp; tmp=$(mktemp -d)
  if ! "${CURL[@]}" -fsSL "$1" | tar -xz -C "$tmp"; then
    rm -rf "$tmp"; warn "download/extract failed: $1"; return 1
  fi
  echo "$tmp"
}

# install_bins <tmpdir> <name>... — locate each binary anywhere under tmpdir,
# copy it into $BIN (executable), remove tmpdir, and return non-zero if any
# requested binary was missing.
install_bins() {
  local tmp=$1 b path rc=0; shift
  for b in "$@"; do
    path=$(find "$tmp" -type f -name "$b" -perm -u+x 2>/dev/null | head -n1)
    [ -n "$path" ] || path=$(find "$tmp" -type f -name "$b" 2>/dev/null | head -n1)
    [ -n "$path" ] || { warn "binary '$b' not found in archive"; rc=1; continue; }
    install -m 0755 "$path" "$BIN/$b"
    msg "installed $b -> $BIN/$b"
  done
  rm -rf "$tmp"
  return "$rc"
}

# ---- per-tool installers -------------------------------------------------

install_nvim() {
  local ver; ver=$(gh_latest neovim/neovim) || return 1
  msg "neovim $ver"
  local tmp; tmp=$(untar_url "https://github.com/neovim/neovim/releases/download/$ver/nvim-linux-${ARCH}.tar.gz") || return 1
  local root; root=$(find "$tmp" -maxdepth 1 -type d -name 'nvim-linux-*' | head -n1)
  [ -n "$root" ] || { warn "unexpected neovim archive layout"; rm -rf "$tmp"; return 1; }
  cp -a "$root"/. "$PREFIX"/
  rm -rf "$tmp"
  msg "installed nvim -> $BIN/nvim (runtime in $PREFIX/share/nvim)"
}

install_node() {
  # newest LTS = first object in dist/index.json whose "lts" is a string.
  # Fetch to a file first: piping into `grep -m1` would SIGPIPE curl (and
  # with `set -o pipefail` that fails the whole pipeline).
  local idx; idx=$(mktemp)
  "${CURL[@]}" -fsSL -o "$idx" https://nodejs.org/dist/index.json \
    || { rm -f "$idx"; warn "could not fetch node release index"; return 1; }
  local ver; ver=$(grep -m1 '"lts":"' "$idx" | sed -E 's/.*"version":"([^"]+)".*/\1/')
  rm -f "$idx"
  [ -n "$ver" ] || { warn "could not determine latest node LTS"; return 1; }
  local uarch; [ "$ARCH" = aarch64 ] && uarch=arm64 || uarch=x64
  msg "node $ver (LTS)"
  local tmp; tmp=$(untar_url "https://nodejs.org/dist/$ver/node-$ver-linux-$uarch.tar.gz") || return 1
  local root; root=$(find "$tmp" -maxdepth 1 -type d -name "node-$ver-linux-$uarch" | head -n1)
  [ -n "$root" ] || { warn "unexpected node archive layout"; rm -rf "$tmp"; return 1; }
  cp -a "$root"/. "$PREFIX"/   # also drops CHANGELOG/LICENSE/README into $PREFIX; harmless
  rm -rf "$tmp"
  msg "installed node -> $BIN/node (npm/npx alongside; modules in $PREFIX/lib/node_modules)"
}

# Most Rust tools ship musl static builds for x86_64; aarch64 tends to be gnu.
rust_libc() { [ "$ARCH" = aarch64 ] && echo gnu || echo musl; }

install_rg() {
  local ver; ver=$(gh_latest BurntSushi/ripgrep) || return 1
  msg "ripgrep $ver"
  local tmp; tmp=$(untar_url "https://github.com/BurntSushi/ripgrep/releases/download/$ver/ripgrep-${ver}-${ARCH}-unknown-linux-$(rust_libc).tar.gz") || return 1
  install_bins "$tmp" rg
}

install_fd() {
  local ver; ver=$(gh_latest sharkdp/fd) || return 1
  msg "fd $ver"
  local tmp; tmp=$(untar_url "https://github.com/sharkdp/fd/releases/download/$ver/fd-${ver}-${ARCH}-unknown-linux-musl.tar.gz") || return 1
  install_bins "$tmp" fd
}

install_eza() {
  # eza assets carry no version in the filename; binary sits at archive root
  local ver; ver=$(gh_latest eza-community/eza) || return 1
  msg "eza $ver"
  local tmp; tmp=$(untar_url "https://github.com/eza-community/eza/releases/download/$ver/eza_${ARCH}-unknown-linux-musl.tar.gz") || return 1
  install_bins "$tmp" eza || return 1
  # eza has no completion generator; fetch the committed _eza for this tag
  if "${CURL[@]}" -fsSL "https://raw.githubusercontent.com/eza-community/eza/$ver/completions/zsh/_eza" -o "$COMP/_eza" && [ -s "$COMP/_eza" ]; then
    msg "completion -> $COMP/_eza"
  else
    rm -f "$COMP/_eza"; warn "eza completion fetch failed"
  fi
}

install_fzf() {
  local ver; ver=$(gh_latest junegunn/fzf) || return 1
  msg "fzf $ver"
  local tmp; tmp=$(untar_url "https://github.com/junegunn/fzf/releases/download/$ver/fzf-${ver#v}-linux_${GOARCH}.tar.gz") || return 1
  install_bins "$tmp" fzf
}

install_lazygit() {
  local ver; ver=$(gh_latest jesseduffield/lazygit) || return 1
  local uarch; [ "$ARCH" = aarch64 ] && uarch=arm64 || uarch=x86_64
  msg "lazygit $ver"
  local tmp; tmp=$(untar_url "https://github.com/jesseduffield/lazygit/releases/download/$ver/lazygit_${ver#v}_Linux_${uarch}.tar.gz") || return 1
  install_bins "$tmp" lazygit
}

install_delta() {
  local ver; ver=$(gh_latest dandavison/delta) || return 1
  msg "delta $ver"
  local tmp; tmp=$(untar_url "https://github.com/dandavison/delta/releases/download/$ver/delta-${ver}-${ARCH}-unknown-linux-$(rust_libc).tar.gz") || return 1
  install_bins "$tmp" delta
}

install_tree_sitter() {
  # release asset tree-sitter-linux-<arch>.gz is the gzipped binary itself.
  # Pinned: the 0.26.x binaries are built against glibc 2.39 (Ubuntu 24.04)
  # and won't run on older hosts; 0.25.10 only needs glibc 2.34. Bump when
  # the build hosts you care about catch up.
  local ver=v0.25.10
  local uarch; [ "$ARCH" = aarch64 ] && uarch=arm64 || uarch=x64
  msg "tree-sitter $ver (pinned)"
  local tmp; tmp=$(mktemp)
  if "${CURL[@]}" -fsSL "https://github.com/tree-sitter/tree-sitter/releases/download/$ver/tree-sitter-linux-${uarch}.gz" | gzip -dc > "$tmp"; then
    install -m 0755 "$tmp" "$BIN/tree-sitter"; rm -f "$tmp"
    msg "installed tree-sitter -> $BIN/tree-sitter"
  else
    rm -f "$tmp"; warn "tree-sitter download failed"; return 1
  fi
}

install_starship() {
  # starship ships musl static builds for both x86_64 and aarch64
  local ver; ver=$(gh_latest starship/starship) || return 1
  msg "starship $ver"
  local tmp; tmp=$(untar_url "https://github.com/starship/starship/releases/download/$ver/starship-${ARCH}-unknown-linux-musl.tar.gz") || return 1
  install_bins "$tmp" starship
}

install_uv() {
  # archive contains both uv and uvx at the root
  local ver; ver=$(gh_latest astral-sh/uv) || return 1
  msg "uv $ver"
  local tmp; tmp=$(untar_url "https://github.com/astral-sh/uv/releases/download/$ver/uv-${ARCH}-unknown-linux-musl.tar.gz") || return 1
  install_bins "$tmp" uv uvx
}

install_copilot() {
  # GitHub Copilot CLI ships a self-contained executable (no Node runtime);
  # the linux-<arch> asset is the glibc build (SUSE/SLES and most distros).
  # A linuxmusl-<arch> variant also exists for musl hosts (e.g. Alpine).
  # Needs an active Copilot seat; auth with `copilot` then `/login`.
  local ver; ver=$(gh_latest github/copilot-cli) || return 1
  local uarch; [ "$ARCH" = aarch64 ] && uarch=arm64 || uarch=x64
  msg "copilot $ver"
  local tmp; tmp=$(untar_url "https://github.com/github/copilot-cli/releases/download/$ver/copilot-linux-${uarch}.tar.gz") || return 1
  install_bins "$tmp" copilot
}

install_direnv() {
  # direnv ships a single static binary per platform (raw, not archived/gzipped).
  # Asset is direnv.linux-<goarch>; GOARCH is amd64/arm64 from above.
  # Activate per-shell with: command -v direnv >/dev/null && eval "$(direnv hook zsh)"
  local ver; ver=$(gh_latest direnv/direnv) || return 1
  msg "direnv $ver"
  local tmp; tmp=$(mktemp)
  if "${CURL[@]}" -fsSL "https://github.com/direnv/direnv/releases/download/$ver/direnv.linux-${GOARCH}" -o "$tmp"; then
    install -m 0755 "$tmp" "$BIN/direnv"; rm -f "$tmp"
    msg "installed direnv -> $BIN/direnv"
  else
    rm -f "$tmp"; warn "direnv download failed"; return 1
  fi
}

# ---- shell completions ---------------------------------------------------
# Cache zsh completion functions into $COMP (placed on fpath by ~/.zshrc) for
# the tools that can emit one. Regenerated every run so they track updates.
# Omitted on purpose: fzf (~/.zshrc loads `source <(fzf --zsh)`, which bundles
# completion + key bindings), eza (no generator — handled in install_eza), and
# nvim/node/lazygit-TUI/direnv/copilot (nothing useful to generate).
declare -A COMPGEN=(
  [rg]='--generate complete-zsh'    [fd]='--gen-completions zsh'
  [delta]='--generate-completion zsh' [lazygit]='completion zsh'
  [tree-sitter]='complete --shell zsh' [starship]='completions zsh'
  [uv]='generate-shell-completion zsh'
)

# shellcheck disable=SC2086  # $args is a deliberately word-split argument list
gen_completions() {
  local t args
  for t in "${!COMPGEN[@]}"; do
    [ -x "$BIN/$t" ] || continue          # only for tools actually installed here
    args=${COMPGEN[$t]}
    if "$BIN/$t" $args > "$COMP/_$t" 2>/dev/null && [ -s "$COMP/_$t" ]; then
      msg "completion -> $COMP/_$t"
    else
      rm -f "$COMP/_$t"; warn "could not generate $t completion"
    fi
  done
  # uv installs uvx alongside it; give uvx its own completion too
  if [ -x "$BIN/uvx" ] && "$BIN/uvx" --generate-shell-completion zsh > "$COMP/_uvx" 2>/dev/null && [ -s "$COMP/_uvx" ]; then
    msg "completion -> $COMP/_uvx"
  fi
}

# ---- driver --------------------------------------------------------------

declare -A TOOLS=(
  [nvim]=install_nvim       [node]=install_node       [rg]=install_rg
  [fd]=install_fd           [eza]=install_eza         [fzf]=install_fzf
  [lazygit]=install_lazygit [delta]=install_delta     [tree-sitter]=install_tree_sitter
  [starship]=install_starship [uv]=install_uv          [copilot]=install_copilot
  [direnv]=install_direnv
)

if [ "$#" -gt 0 ]; then
  for t in "$@"; do [ -n "${TOOLS[$t]:-}" ] || { echo "unknown tool: $t (see --list)" >&2; exit 1; }; done
  sel=("$@")
else
  sel=("${ORDER[@]}")
fi

rc=0
for t in "${sel[@]}"; do
  fn=${TOOLS[$t]:-}
  [ -n "$fn" ] || { warn "no installer for '$t' (ORDER/TOOLS drift)"; rc=1; continue; }
  "$fn" || { warn "failed: $t"; rc=1; }
done

gen_completions   # refresh zsh completions for whatever is now installed

case ":$PATH:" in *":$BIN:"*) ;; *) warn "$BIN is not on PATH (login zsh adds it via ~/.zprofile)";; esac
exit "$rc"
