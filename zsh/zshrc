# Homebrew completions (only if brew is installed)
if type brew &>/dev/null; then
  FPATH="$(brew --prefix)/share/zsh/site-functions:${FPATH}"
fi

autoload -Uz compinit
compinit

# Bash-like completion behavior: complete stem, list on ambiguity
setopt no_auto_menu
setopt bash_auto_list
setopt list_ambiguous
setopt no_menu_complete
setopt list_types
unsetopt rec_exact
setopt auto_menu

zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*:default' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' list-separator '--'

source ~/dotfiles/shell/aliases

# fzf keybindings (env vars set in shell/aliases)
if type brew &>/dev/null; then
  _fzf_key="$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
else
  _fzf_key="/usr/share/fzf/shell/key-bindings.zsh"
fi
[[ -r "$_fzf_key" ]] && source "$_fzf_key"
unset _fzf_key

# direnv (if installed)
if type direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# Prompt: starship if installed, otherwise a simple fallback
if type starship &>/dev/null; then
  eval "$(starship init zsh)"
else
  PROMPT='%F{blue}%~%f %# '
fi

# Machine-specific overrides (not tracked)
[[ -r ~/.zshrc.local ]] && source ~/.zshrc.local
